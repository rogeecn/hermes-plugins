# ─────────────────────────────────────────────────────────────
# Hermes Plugins — Environment Variables Example
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# These variables are read by the plugins under ~/.hermes/plugins/
# (or ./<repo>/.hermes/plugins/ when HERMES_ENABLE_PROJECT_PLUGINS=1).
# ─────────────────────────────────────────────────────────────

# Enable project-level plugins discovery (./.hermes/plugins/)
HERMES_ENABLE_PROJECT_PLUGINS=1

# ── CPA Model Provider ──────────────────────────────────────
# Used by: model-providers/cpa
# OpenAI-compatible endpoint for chat models.
# Get your key from the CPA platform (QAX internal).

# Your CPA API key
CPA_API_KEY=your-cpa-api-key-here

# Optional: override the default base URL
# Default: http://10.58.144.6:2014/v1
# CPA_BASE_URL=http://your-cpa-host:port/v1

# ── Agnes AI Image & Video Generation ───────────────────────
# Used by: agnes-ai/image_gen, agnes-ai/video_gen
# API docs: https://agnes-ai.com/zh-Hans/docs/quickstart
# Get your key from: https://agnes-ai.com developer console

# Your Agnes AI API key (Bearer token)
AGNES_API_KEY=your-agnes-api-key-here

# Optional: override the default base URL
# Default: https://apihub.agnes-ai.com/v1
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# ── MemOS Memory Provider (optional) ─────────────────────────
# Used by: memos plugin (if enabled)
# Self-hosted MemOS or MemOS Cloud

# MEMOS_API_KEY=your-memos-api-key
# MEMOS_BASE_URL=https://memos.memtensor.cn/api/openmem/v1
# MEMOS_USER_ID=hermes-default
